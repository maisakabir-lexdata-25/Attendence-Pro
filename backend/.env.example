# ─── Option A: Google Sheets ────────────────────────────────────────────────
# For public sheets:
GOOGLE_API_KEY=your_google_api_key_here
# For private sheets:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ─── Option B: Microsoft Graph API (Office 365 Excel / SharePoint) ──────────
# Leave Google Sheets vars empty if using Microsoft Graph API
MS_TENANT_ID=your_azure_tenant_id
MS_CLIENT_ID=your_azure_client_id
MS_CLIENT_SECRET=your_azure_client_secret
MS_DRIVE_ID=your_sharepoint_or_onedrive_drive_id
# MS_SITE_ID=your_sharepoint_site_id (use this instead of DRIVE_ID if needed)

# ─── Auth ───────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret-string
JWT_EXPIRES=8h

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3000
FRONTEND_ORIGIN=http://localhost:5500

# ─── Cache ──────────────────────────────────────────────────────────────────
CACHE_TTL_MS=60000

# ─── Default Sheet (for server-side auto-refresh) ───────────────────────────
DEFAULT_SHEET_ID=
DEFAULT_RANGE=Sheet1
AUTO_REFRESH_SECS=60
